    <html lang="uk">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{title}} | Service Center</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="bg-light">

    <nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4 shadow">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/">Sloniki</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    {{#if user}}
                        {{#if (eq user.role 'master')}}
                            <li class="nav-item"><a class="nav-link" href="/api/master/dashboard">Master Dashboard</a></li>
                        {{/if}}
                        {{#if (eq user.role 'admin')}}
                            <li class="nav-item"><a class="nav-link" href="/api/admin/dashboard">Admin Dashboard</a></li>
                        {{/if}}
                        <li class="nav-item"><a class="nav-link" href="/api/client/dashboard">My Orders</a></li>
                    {{/if}}
                </ul>
                <div class="navbar-nav">
                    {{#if user}}
                        <span class="nav-link text-info me-3">Hello, {{user.email}}</span>
                        <a class="btn btn-outline-danger btn-sm" href="/api/auth/logout">Logout</a>
                    {{else}}
                        <a class="nav-link" href="/login">Login</a>
                        <a class="nav-link btn btn-primary btn-sm text-white ms-lg-2" href="/register">Register</a>
                    {{/if}}
                </div>
            </div>
        </div>
    </nav>

    <main class="container">
        {{{body}}} {{!-- Сюди вставлятиметься контент кожної сторінки --}}
    </main>

    <footer class="text-center mt-5 py-3 text-muted border-top">
        <p>&copy; 2026 Service Center "Sloniki". All rights reserved.</p>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>